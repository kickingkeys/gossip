# LLM Provider
ANTHROPIC_API_KEY=

# Discord Bot (create at https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_FREE_RESPONSE_CHANNELS=       # comma-separated channel IDs
DISCORD_REQUIRE_MENTION=false

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=

# Bot's Google Account
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=                  # bot's own account, obtained during setup

# Google OAuth for Members (same Google Cloud project)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Bot's Gmail (for email forwarding)
GOSSIP_EMAIL=gossipbot@gmail.com
GOSSIP_EMAIL_PASSWORD=

# Instagram (optional, from developers.facebook.com)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Twitter/X (optional, from developer.x.com)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Image Generation (optional, from fal.ai)
FAL_KEY=

# Portal
PORTAL_HOST=0.0.0.0
PORTAL_PORT=3000
PORTAL_SECRET_KEY=                     # auto-generated during setup

# Hermes
HERMES_MODEL=anthropic/claude-sonnet-4-20250514
HERMES_REASONING_EFFORT=medium
